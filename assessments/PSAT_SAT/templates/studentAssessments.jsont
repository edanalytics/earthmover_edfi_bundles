{% set generic_score_results = [

  ["Total Score", total_score,"Integer"],
  ["Subject",subject,"Level"]
  ["Nationally Rep Sample Pctl Total Score", nationally_representative_total_score,"Level"]
  ["User Percentile Total Score", user_percentile_total_score,"Level"]

] %}


{% set objective_assessment_scores_results  = [

      -- reading specific objective assessment
      ['Reading Test Score', reading_test_score, "Level"],
      ['Nationall Representative Reading Test Score', nationally_representative_reading_test_score, "Integer"],
      ['User Percentile Reading Test Score', user_percentile_reading_test_score, "Integer"],
      ['Number of Reading Test Questions', number_of_reading_test_questions, "Integer"],
      ['Correct Answers to Reading Test Questions', student_correct_answers_to_reading_test_questions, "Integer"],
      ['Incorrect Answers to Reading Test Questions', student_incorrect_answers_to_reading_test_questions, "Integer"],
      ['Omitted Reading Test Questions', student_omitted_reading_test_questions, "Integer"],
      ["Reading Writing Section Score", reading_writing_section_score, "Integer"],
      ["Nationally Rep Sample Pctl Reading Writing Section Score", nationally_representative_reading_writing_section_score,"Level"],
      ["User Percentile Section Reading Writing Score", user_percentile_reading_writing_section_score,"Level"],
      ["Math Section Score", math_section_score,"Integer"],
      ["Nationally Rep Sample Pctl Math Section Score", nationally_representative_math_section_score,"Level"],
      ["User Percentile Section Math Score", user_percentile_math_section_score,"Level"],
      ["Analysis in Science Cross-Test Score", analysis_in_science_xtest_score,"Level"],
      ["Analysis in History Social Sci Cross-Test Score", analysis_in_history_xtest_score,"Level"]
      ['Writing Section Score', writing_lang_test_score, "Integer"],
      ['Nationally Rep Sample Pctl Writing Score', nationally_representative_writing_lang_test_score,"Integer"],
      ['User Percentile Writing Score',user_percentile_writing_lang_test_score,"Integer"],
      ['Number of Writing Test Questions', number_of_writing_and_lang_test_questions,"Level"],
      ['Correct Answers to Writing Test Questions',student_correct_answers_to_writing_and_lang_test_questions,"Level"],
      ['Incorrect Answers to Writing Test Questions',student_incorrect_answers_to_writing_and_lang_test_questions,"Level"],
      ['Omitted Writing Test Questions',student_omitted_writing_and_lang_test_question,"Level"],
      ['Relevent Words in Context Subscore',relevant_words_in_context_subscore,"Level"],
      ['Nationally Rep Sample Pctl Relevant Words Subscore',nationally_representative_relevant_words_in_context_subscore,"Level"],
      ['User Percentile Relevant Words Subscore',user_percentile_relevant_words_in_context_subscore,"Level"],
      ['Command of Evidence Subscore',command_of_evidence_subscore,"Level"],
      ['Nationally Rep Sample Pctl Command of Evidence Subscore', nationally_representative_command_of_evidence_subscore,"Level"]
      ['User Percentile Command of Evidence Subscore', user_percentile_command_of_evidence_subscore, "Level"],
      ['Expression of Ideas Subscore',expression_of_ideas_subscore,"Level"],
      ['Nationally Rep Sample Pctl Expression of Ideas Subscore',nationally_representative_expression_of_ideas_subscore, "Level"],
      ['User Percentile Expression of Ideas Subscore',user_percentile_expression_of_ideas_subscore, "Level"],
      ['Standard English Conventions Subscore', standard_english_conventions_subscore,"Level"],
      ['Nationally Rep Sample Pctl Standard English Conventions Subscore',nationally_representative_standard_english_conventions_subscore,"Level"],
      ['User Percentile Standard English Conventions Subscore',user_percentile_standard_english_conventions_subscore, "Level"],

      {% if test_type == "SAT" and essay_reading_subscore != '' %}
        {% set _= objective_assessment_scores_results.append(
                        ['Essay Reading Subscore',essay_reading_subscore,"Level"],
                        ['Essay Analysis Subscore',essay_analysis_subscore,"Level"],
                        ['Essay Writing Subscore',essay_writing_subscore,"Level"]) %}      
      {% endif %}  

      ['Math Score',math_test_score,"Integer"],
      ['Nationally Rep Sample Pctl Math Score',nationally_representative_math_test_score,"Level"],
      ['User Percentile Math Score',user_percentile_math_test_score,"Level"],
      ['Number of Math No Calc Test MC Questions',number_of_math_no_calc_test_mult_choice_questions,"Level"],
      ['Number of Math No Calc Test PR Questions',number_of_math_no_calc_test_produced_response_questions,"Level"],
      ['Correct Answers to Math No Calc Test Questions',student_correct_answers_to_math_no_calc_test_questions,"Level"]
      ['Incorrect Answers to Math No Calc Test Questions',student_incorrect_answers_to_math_no_calc_test_questions,"Level"]
      ['Omitted Math No Calc Test Questions',student_omitted_math_no_calc_test_questions,"Level"],
      ['Number of Math Calc Test MC Questions',number_of_math_calc_test_mult_choice_questions,"Level"],
      ['Number of Math Calc Test PR Questions',number_of_math_calc_test_produced_response_questions,"Level"],
      ['Correct Answers to Math Calc Test Questions',student_correct_answers_to_math_calc_test_questions,"Level"],
      ['Incorrect Answers to Math Calc Test Questions',student_incorrect_answers_to_math_calc_test_questions,"Level"],
      ['Omitted Math Calc Test Questions',student_omitted_math_calc_test_questions,"Level"],
      ['Heart of Algebra Subscore',heart_of_algebra_subscore,"Integer"],
      ['Nationally Rep Sample Pctl Heart of Algebra Subscore',nationally_representative_heart_of_algebra_subscore,"Level"],
      ['User Percentile Heart of Algebra Subscore',user_percentile_heart_of_algebra_subscore, "Level"],
      ['Problem Solving and Data Analysis Subscore',problem_solving_and_data_analysis_subscore,"Level"],
      ['Nationally Rep Sample Pctl Problem Solving and Data Analysis Subscore',nationally_representative_problem_solving_and_data_analysis_subscore,"Level"],
      ['User Percentile Problem Solving and Data Analysis Subscore',user_percentile_problem_solving_and_data_analysis_subscore, "Level"]
    
      {% if test_type in ("SAT", "PSAT/NMSQT", "PSAT 10") %}
        {% set _= objective_assessment_scores_results.append(
          ['Passport to Advanced Mathematics Subscore',passport_to_advanced_math_subscore,"Integer"],
          ['Nationally Rep Sample Pctl Passport to Advanced Mathematics Subscore',nationally_representative_passport_to_advanced_math_subscore,"Level],
          ['User Percentile Passport to Advanced Mathematics Subscore',user_percentile_passport_to_advanced_math_subscore,"Level"]) %}
      {% endif %}

  ]

{% set objective_assessment_perf_level  = [

  ['Reading Writing CCR Benchmark Indicator',reading_writing_ccr_benchmark_indicator,"Level"],
  ['Math CCR Benchmark Indicator',math_ccr_benchmark_indicator,"Level"]

] %}


{
    "studentAssessmentIdentifier": "{{student_assessment_id}}",
    "assessmentReference": {
      "assessmentIdentifier": "{{test_type}}",
      "namespace": "uri://collegeboard.org"
    },
    "schoolYearTypeReference": {
      "schoolYear": "{{school_year}}"
    },
    "studentReference": {
      "studentUniqueId": "{{studentUniqueId}}"
    },
    "administrationDate": "{{assessment_date}}",
    {%- if score_results -%}
    "scoreResults": [
      {%- for score in score_results -%}
      {
        "assessmentReportingMethodDescriptor": "uri://collegeboard.org/AssessmentReportingMethodDescriptor#{{score[0]}}",
        "resultDatatypeTypeDescriptor": "uri://collegeboard.org/ResultDatatypeTypeDescriptor#{{score[2]}}",
        "result": {% if score[2] == 'Integer' -%}"{{score[1] | int}}"{%- else -%}"{{score[1]}}"{%- endif %}
      } {%- if not loop.last -%},{%- endif -%}
      {%- endfor -%}
  ],
    {%- endif -%}
     {%- if objective_assessments -%}
  "studentObjectiveAssessments": [
    {%- for obj_assess in objective_assessments -%}
    {
      "objectiveAssessmentReference": {
        "assessmentIdentifier": "{{ assessment_identifier }}",
        "identificationCode": "{{ obj_assess[1] }}",
        "namespace": "uri://datarecognitioncorp.com/Assessment"
      },
      {# only two performance level, not all score results in the objective assessment has perf level, might need logic here if score results = reading_writing_score
      fill in with perf level of reading? #}
      "performanceLevels": [
        {
          "assessmentReportingMethodDescriptor": "uri://datarecognitioncorp.com/AssessmentReportingMethodDescriptor#{{ obj_assess[2] }}",
          "performanceLevelDescriptor": "uri://datarecognitioncorp.com/PerformanceLevelDescriptor#{{ obj_assess[0] | int}}",
          "performanceLevelMet": true
        }
      ],
      "scoreResults": [
        {
          "assessmentReportingMethodDescriptor": "uri://datarecognitioncorp.com/AssessmentReportingMethodDescriptor#{{ obj_assess[0] }}",
          "resultDatatypeTypeDescriptor": "uri://ed-fi.org/ResultDatatypeTypeDescriptor#{{obj_assess[2]}}",
          "result": "{{ obj_assess[1] | int}}"
        }
      ]
    } {%-if not loop.last -%}, {%- endif -%}
    {%- endfor -%}
  ],
  {%- endif -%}
    {% if grade_when_assessed != '' %}
    ,
    "whenAssessedGradeLevelDescriptor": "uri://ed-fi.org/GradeLevelDescriptor#{{grade_when_assessed}}"
    {% endif %}
  }